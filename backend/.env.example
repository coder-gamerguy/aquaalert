# AquaAlert Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/aquaalert

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# SMS Gateway — Primary: Hubtel (Ghana)
HUBTEL_CLIENT_ID=your-hubtel-client-id
HUBTEL_CLIENT_SECRET=your-hubtel-client-secret
HUBTEL_SENDER_ID=AquaAlert

# SMS Gateway — Fallback: Arkesel (Ghana)
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=GWCL-Alert

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Twilio fallback (international)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
